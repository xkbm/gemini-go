<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="80dp" android:layout_height="80dp" android:layout_marginEnd="8dp">
    <ImageView android:id="@+id/imageThumb" android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@drawable/bg_input_field" android:scaleType="centerCrop" />
    <com.google.android.material.button.MaterialButton android:id="@+id/btnRemove"
        style="@style/Widget.Material3.Button.IconButton" android:layout_width="24dp" android:layout_height="24dp"
        android:layout_gravity="top|end" android:backgroundTint="@android:color/black"
        android:contentDescription="@string/action_delete" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp"
        android:padding="0dp" app:icon="@drawable/ic_close" app:iconSize="14dp" app:iconTint="@android:color/white" />
</FrameLayout>
